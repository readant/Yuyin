[{"time": 21.0, "text": "《此生不换》- 青鸟飞鱼", "index": 0}, {"time": 30.0, "text": "时光穿不断 流转在从前", "index": 1}, {"time": 38.0, "text": "刻骨的变迁 不是遥远", "index": 2}, {"time": 46.0, "text": "再有一万年 深情也不变", "index": 3}, {"time": 54.0, "text": "爱像烈火般蔓延", "index": 4}, {"time": 64.0, "text": "记忆是条长线 盘旋在天边", "index": 5}, {"time": 72.0, "text": "沉浮中以为 情深缘浅", "index": 6}, {"time": 80.0, "text": "你再度出现 我看见誓言", "index": 7}, {"time": 88.0, "text": "承诺在水天之间", "index": 8}, {"time": 98.0, "text": "回头看 不曾走远", "index": 9}, {"time": 106.0, "text": "依依目光此生不换", "index": 10}, {"time": 114.0, "text": "要分散 不习惯", "index": 11}, {"time": 121.0, "text": "怎么算 都太难", "index": 12}, {"time": 125.0, "text": "分开之后更勇敢", "index": 13}, {"time": 132.0, "text": "愿这爱 世代相传", "index": 14}, {"time": 140.0, "text": "喝不完忘情水 不让你如烟", "index": 15}, {"time": 148.0, "text": "前尘再怀念 望剑如面", "index": 16}, {"time": 156.0, "text": "挥舞的瞬间 别再闭上眼", "index": 17}, {"time": 164.0, "text": "错过惊世的依恋", "index": 18}, {"time": 172.0, "text": "回头看 不曾走远", "index": 19}, {"time": 180.0, "text": "眷恋一人流连忘返", "index": 20}, {"time": 188.0, "text": "多少汗 够温暖", "index": 21}, {"time": 194.0, "text": "你哭喊 我呼唤", "index": 22}, {"time": 199.0, "text": "听清耳边的呢喃", "index": 23}, {"time": 207.0, "text": "别害怕 风轻云淡", "index": 24}, {"time": 215.0, "text": "回头看 不曾走远", "index": 25}, {"time": 223.0, "text": "依依目光此生不换", "index": 26}, {"time": 230.0, "text": "要分散 不习惯", "index": 27}, {"time": 238.0, "text": "怎么算 都太难", "index": 28}, {"time": 243.0, "text": "分开之后更勇敢", "index": 29}, {"time": 252.0, "text": "愿这爱 世代相传", "index": 30}]